<launch>

<rosparam file="$(find humanoid_urdf_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="humanoid_urdf" args="lgripper_joint_position_controller lgrip_fin2_slider_position_controller lgrip_fin1_slider_position_controller lshd_yaw_joint_position_controller lwrist_pitch_joint_position_controller lwrist_yaw_joint_position_controller rwrist_pitch_joint_position_controller rwrist_yaw_joint_position_controller rgripper_joint_position_controller rgrip_fin1_slider_position_controller rgrip_fin2_slider_position_controller rshd_pitch_joint_position_controller lshd_pitch_joint_position_controller neck_roll_joint_position_controller neck_pitch_joint_position_controller lbase_joint_position_controller ll1_joint_position_controller rbase_joint_position_controller rl3_joint_position_controller rl5_joint_position_controller ll2_joint_position_controller ll3_joint_position_controller ll5_joint_position_controller rl1_joint_position_controller rl2_joint_position_controller lshd_roll_joint_position_controller lelbow_joint_position_controller rshd_roll_joint_position_controller relbow_joint_position_controller ll4_joint_position_controller rl4_joint_position_controller rshd_yaw_joint_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/humanoid_urdf/joint_states"/>
</node>

</launch>